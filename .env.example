# Copy to .env and fill in. .env is gitignored.

# LLM selection: local | openai | anthropic
LLM_MODE=openai

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional data source keys
DATAGOV_API_KEY=
NEWSAPI_KEY=
OPENWEATHER_KEY=
TWITTER_BEARER_TOKEN=

# Security (required for API + at-rest encryption)
# Generate AUTH_SECRET: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Generate CRYPTO_KEY: python -c "from src.security.crypto import generate_key; print(generate_key())"
AUTH_SECRET=
CRYPTO_KEY=
RETENTION_AUDIT_DAYS=365
RETENTION_SCRAPE_DAYS=30

# Paths
ASTRAM_DATA_PATH=data/raw/astram.xlsx
